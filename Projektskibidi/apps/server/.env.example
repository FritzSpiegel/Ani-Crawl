# =============================================================================
# AniCrawl Headless CMS - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/anicrawl_dev

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
API_PORT=3002
BASE_URL=http://localhost:3002
NODE_ENV=development

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Initial admin credentials (used for first login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# -----------------------------------------------------------------------------
# Headless CMS Configuration
# -----------------------------------------------------------------------------

# Rate limiting for CMS API (requests per hour for anonymous users)
CMS_RATE_LIMIT=1000

# Default API key rate limit (requests per hour)
DEFAULT_API_KEY_RATE_LIMIT=1000

# -----------------------------------------------------------------------------
# Media Upload
# -----------------------------------------------------------------------------

# Directory for uploaded files
UPLOAD_DIR=./uploads

# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# Crawler Settings
# -----------------------------------------------------------------------------

# Static fixture files for testing
STATIC_SEARCH_HTML=fixtures/search.html
STATIC_DETAIL_HTML=fixtures/detail.html

# Allow live web fetching (set to true in production)
ALLOW_LIVE_FETCH=false

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
EMAIL_FROM="AniCrawl <no-reply@example.com>"

# -----------------------------------------------------------------------------
# Webhook Configuration
# -----------------------------------------------------------------------------

# Timeout for webhook HTTP requests (ms)
WEBHOOK_TIMEOUT=10000

# Maximum consecutive failures before disabling webhook
WEBHOOK_MAX_FAILURES=10
