{
    "kind": "collectionType",
    "collectionName": "genres",
    "info": {
        "singularName": "genre",
        "pluralName": "genres",
        "displayName": "Genre",
        "description": "Anime genres"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "animes": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::anime.anime",
            "mappedBy": "genres"
        }
    }
}